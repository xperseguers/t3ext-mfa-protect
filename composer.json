{
  "name": "causal/mfa-protect",
  "type": "typo3-cms-extension",
  "description": "Protect rendering of sensitive content elements with MFA.",
  "keywords": [
    "TYPO3 CMS",
    "MFA",
    "2FA",
    "secure",
    "security",
    "protection"
  ],
  "support": {
    "docs": "https://docs.typo3.org/p/causal/mfa-protect/main/en-us/",
    "issues": "https://github.com/xperseguers/t3ext-mfa-protect/issues",
    "source": "https://github.com/xperseguers/t3ext-mfa-protect"
  },
  "authors": [
    {
      "name": "Xavier Perseguers",
      "email": "xavier@causal.ch",
      "homepage": "https://www.causal.ch",
      "role": "Developer"
    }
  ],
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.1.0 <=8.5.99",
    "typo3/cms-core": "^12 || ^13 || ^14"
  },
  "suggest": {
    "causal/mfa-frontend": "Enable MFA (Multi-Factor Authentication) for Frontend accounts."
  },
  "autoload": {
    "psr-4": {
      "Causal\\MfaProtect\\": "Classes/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.3.x-dev"
    },
    "typo3/cms": {
      "extension-key": "mfa_protect"
    }
  }
}
